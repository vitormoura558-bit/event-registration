<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel Admin - Sistema de Eventos</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .admin-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-box {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 1.5rem;
      border-radius: 10px;
      text-align: center;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .stat-box h3 {
      margin: 0 0 0.5rem 0;
      font-size: 0.9rem;
      opacity: 0.9;
      color: white;
    }

    .stat-box .number {
      font-size: 2.5rem;
      font-weight: bold;
    }

    .stat-pendente {
      background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    }

    .stat-confirmado {
      background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    }
  </style>
</head>

<body>
  <header>
    <h1>🔐 Painel Administrativo</h1>
    <p>Visualizar todas as inscrições de eventos</p>
  </header>

  <div class="container">
    <div class="card">
      <div class="admin-stats">
        <div class="stat-box">
          <h3>Total de Inscrições</h3>
          <div class="number">
            <%= inscriptions.length %>
          </div>
        </div>
        <div class="stat-box stat-pendente">
          <h3>Pendentes</h3>
          <div class="number">
            <%= inscriptions.filter(i=> i.status === 'PENDENTE').length %>
          </div>
        </div>
        <div class="stat-box stat-confirmado">
          <h3>Confirmadas</h3>
          <div class="number">
            <%= inscriptions.filter(i=> i.status === 'CONFIRMADO').length %>
          </div>
        </div>
        <div class="stat-box">
          <h3>Total de Líderes</h3>
          <div class="number">
            <%= leaderCount %>
          </div>
        </div>
      </div>

      <% if (passwordMessage) { %>
        <div class="message-box message-success">
          <p><%= passwordMessage %></p>
        </div>
      <% } %>

      <% if (passwordError) { %>
        <div class="message-box message-error">
          <p><%= passwordError %></p>
        </div>
      <% } %>

      <% if (leaderMessage) { %>
        <div class="message-box message-success">
          <p><%= leaderMessage %></p>
        </div>
      <% } %>

      <% if (leaderError) { %>
        <div class="message-box message-error">
          <p><%= leaderError %></p>
        </div>
      <% } %>

      <div class="card" style="margin-bottom: 2rem;">
        <h2>Senha Global dos Líderes</h2>
        <p>
          Status:
          <strong><%= leaderPasswordConfigured ? 'Configurada' : 'Não configurada' %></strong>
        </p>
        <form action="/painel/admin/leader-password" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group">
            <label for="leader_password">Nova senha dos líderes</label>
            <input type="password" id="leader_password" name="leader_password" required placeholder="Digite a senha global">
          </div>
          <button type="submit" class="btn">Salvar senha global</button>
        </form>
      </div>

      <div class="card" style="margin-bottom: 2rem;">
        <h2>Gerenciar Líderes</h2>
        <form action="/painel/admin/leaders" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Nome do líder</label>
              <input type="text" id="name" name="name" required placeholder="Ex: João Silva">
            </div>
            <div class="form-group">
              <label for="whatsapp">WhatsApp</label>
              <input type="text" id="whatsapp" name="whatsapp" required placeholder="Ex: (11) 99999-9999">
            </div>
          </div>
          <div class="form-group">
            <label for="link_name">Link do grupo</label>
            <input type="text" id="link_name" name="link_name" required placeholder="Ex: grupo-joao">
          </div>
          <button type="submit" class="btn">Cadastrar líder</button>
        </form>

        <% if (leaders.length === 0) { %>
          <div class="message-box message-info">
            <p>Nenhum líder cadastrado.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>Nome</th>
                  <th class="col-phone">WhatsApp</th>
                  <th>Link</th>
                  <th>Inscrições</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% leaders.forEach(function(leader){ %>
                  <tr>
                    <td>
                      <form action="/painel/admin/leaders/<%= leader.id %>/update" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="text" name="name" value="<%= leader.name %>" required>
                    </td>
                    <td class="col-phone">
                        <input type="text" name="whatsapp" value="<%= leader.whatsapp %>" required>
                    </td>
                    <td>
                        <input type="text" name="link_name" value="<%= leader.link_name %>" required>
                    </td>
                    <td><%= leader.inscription_count %></td>
                    <td>
                        <button type="submit" class="btn btn-secondary small-btn">Salvar</button>
                      </form>
                      <% if (leader.inscription_count > 0) { %>
                        <span class="confirmed-label">Possui inscrições vinculadas</span>
                      <% } else { %>
                        <form action="/painel/admin/leaders/<%= leader.id %>/delete" method="POST" class="inline-form">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-danger small-btn">Remover</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <% if(inscriptions.length===0) { %>
        <div class="message-box message-info">
          <p>Nenhuma inscrição encontrada no sistema.</p>
        </div>
        <% } else { %>
          <div class="table-responsive">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Nome</th>
                  <th class="col-phone">Telefone</th>
                  <th class="col-leader">Líder/Grupo</th>
                  <th class="col-payment">Pagamento</th>
                  <th>St. Pagto</th>
                  <th class="col-date">Data Pgto</th>
                  <th>Status Inscrição</th>
                </tr>
              </thead>
              <tbody>
                <% inscriptions.forEach(function(i){ %>
                  <tr>
                    <td><strong>#<%= i.id %></strong></td>
                    <td>
                      <%= i.name %>
                    </td>
                    <td class="col-phone"><a href="https://wa.me/<%= i.phone.replace(/\D/g, '') %>" target="_blank">
                        <%= i.phone %>
                      </a></td>
                    <td class="col-leader">
                      <%= i.leader_name || i.link_name %>
                    </td>
                    <td>
                      <% if(i.payment_method==='PIX' ) { %>
                        💳 PIX
                        <% } else if(i.payment_method==='Presencial' ) { %>
                          💰 Presencial
                          <% } else { %>
                            <%= i.payment_method %>
                              <% } %>
                    </td>
                    <td>
                      <span class="status-badge <%= i.payment_status === 'PAID' ? 'status-confirmado' : 'status-pendente' %>">
                        <%= i.payment_status || 'PENDING' %>
                      </span>
                    </td>
                    <td>
                      <%= i.paid_at ? new Date(i.paid_at).toLocaleDateString('pt-BR') : (i.payment_date ? new Date(i.payment_date).toLocaleDateString('pt-BR') : '-') %>
                    </td>
                    <td>
                      <% if(i.status==='PENDENTE' ) { %>
                        <span class="status-badge status-pendente">PENDENTE</span>
                        <% } else { %>
                          <span class="status-badge status-confirmado">CONFIRMADO</span>
                          <% } %>
                    </td>
                  </tr>
                  <% }); %>
              </tbody>
            </table>
          </div>
          <% } %>

            <div style="margin-top: 2rem; text-align: center;">
              <a href="/inscrever" class="btn btn-secondary">← Voltar ao Início</a>
            </div>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 Sistema de Inscrição de Eventos. Todos os direitos reservados.</p>
  </footer>
</body>

</html>

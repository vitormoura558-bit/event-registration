# Exemplo de variáveis de ambiente para o sistema de inscrição
# Substitua pelos seus valores reais antes de rodar

# Chave secreta para sessões (troque em produção)
SESSION_SECRET=algumasecretforte

# Token de acesso do Mercado Pago
MP_ACCESS_TOKEN=seu_token_do_mercadopago

# Segredo para assinar/verificar webhooks do Mercado Pago
MP_WEBHOOK_SECRET=seu_webhook_secret

# Preço do evento (opcional)
EVENT_PRICE=50.00

# Senha global para login de líder
LEADER_PASSWORD=leaderpass

# Intervalo do worker de webhooks (ms)
WEBHOOK_WORKER_INTERVAL_MS=5000

# Porta do servidor
PORT=3000
